{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(gh pr *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git restore *)",
      "Bash(gh api *)",
      "Bash(./node_modules/.bin/tsc --noEmit)",
      "Bash(npm install *)",
      "Bash(python3 -m json.tool)",
      "Bash(chmod +x *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/shadim/src/mwan/.claude/hooks/pre-bash-guard.sh"
          },
          {
            "type": "command",
            "command": "/Users/shadim/src/mwan/.claude/hooks/branch-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/shadim/src/mwan/.claude/hooks/post-bash.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/shadim/src/mwan/.claude/hooks/post-write.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/shadim/src/mwan/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/shadim/src/mwan/.claude/hooks/stop-guard.sh"
          }
        ]
      }
    ]
  }
}
